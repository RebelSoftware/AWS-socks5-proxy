# ── AWS Configuration ──────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ── ECS / Fargate Configuration ────────────────────────────────
ECS_CLUSTER=proxy-cluster
ECS_TASK_DEFINITION=go-socks5-proxy
TASK_SUBNET=subnet-12345678
TASK_SECURITY_GROUP=sg-12345678

# ── Proxy Ports / Network ──────────────────────────────────────
LOCAL_PROXY_PORT=8080          # HTTP proxy port (listens on all interfaces)
HEALTH_PORT=8081               # Internal health check port (LISTEN_PORT + 1)
ORCHESTRATOR_PORT=5000         # Management API port
SOCKS5_PORT=1080               # Remote SOCKS5 proxy port (upstream)

# ── Idle Timeout ───────────────────────────────────────────────
IDLE_TIMEOUT_MINUTES=60        # Remote proxy shuts down after N min idle
WAKING_TIMEOUT_MS=120000       # Timeout before giving up on wake (ms)

# ── IP Allowlist Security (AWS Security Group) ─────────────────
IP_ALLOWLIST_ENABLED=false     # Restrict Fargate port 1080 to your IP
CLIENT_SECURITY_GROUP_ID=      # SG ID to update (required if enabled)
DUAL_IP_RETENTION_MINUTES=180  # Keep old IP in SG during transitions

# ── Upstream SOCKS5 Auth (Fargate) ─────────────────────────────
REQUIRE_AUTH=false             # Require SOCKS5 username/password
PROXY_USER=
PROXY_PASSWORD=

# ── Local Proxy Auth (LAN / multi-device) ──────────────────────
LOCAL_REQUIRE_AUTH=false       # Require auth for the local HTTP proxy
LOCAL_PROXY_USER=
LOCAL_PROXY_PASSWORD=

# ── Logging / Tuning ───────────────────────────────────────────
LOG_LEVEL=INFO                 # debug | info | warn | error
CHECK_INTERVAL=30              # Seconds between orchestrator status polls